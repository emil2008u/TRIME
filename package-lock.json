# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS (comma-separated in prod if needed) ─────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Email — SMTP credentials ─────────────────────────────────────────────────
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# Resend: host=smtp.resend.com  port=465  secure=true
# Mailgun: host=smtp.mailgun.org  port=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@trime.agency
SMTP_PASS=your-16-char-app-password

# Name shown in the "From" field of outgoing emails
EMAIL_FROM_NAME=Trime Agency

# Agency inbox that receives lead notifications
CONTACT_RECEIVER=hello@trime.agency

# ─── Rate limiting ────────────────────────────────────────────────────────────
# 10 submissions per IP per 15-minute window (sensible default for a contact form)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10
